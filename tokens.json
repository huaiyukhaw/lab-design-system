{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Lab design tokens, in W3C Design Tokens Community Group (DTCG) format. Extracted verbatim from tailwind.config.js and src/index.css. Importable into Tokens Studio for Figma, Style Dictionary, and similar tooling. Aliases use the {group.token} reference syntax.",

  "color": {
    "$type": "color",

    "brand": {
      "cream": { "$value": "#faf9f5", "$description": "App canvas / page background. The warm off-white the whole system sits on." },
      "ink": { "$value": "#141413", "$description": "Primary text and dark/solid surfaces (e.g. the primary button)." },
      "ink-soft": { "$value": "#3a3733", "$description": "Softer ink for hover on dark surfaces and secondary dark text." },
      "clay": {
        "50": { "$value": "#fbf1ec" },
        "100": { "$value": "#f6ddd1" },
        "200": { "$value": "#eebfa9" },
        "400": { "$value": "#df8c69" },
        "500": { "$value": "#d97757", "$description": "Primary accent. Interactive emphasis, active indicators, focus ring, glow." },
        "600": { "$value": "#c25e3f", "$description": "Accent text on light surfaces (eyebrow labels, active tab number)." },
        "700": { "$value": "#9f4a30" }
      },
      "moss": { "$value": "#788c5d", "$description": "Brand green. Success / pass / positive status." },
      "sky": { "$value": "#6a9bcc", "$description": "Brand blue. Secondary accent (reserved; used sparingly)." }
    },

    "neutral": {
      "$description": "Warm grays. The system deliberately uses Tailwind's `stone` scale because it matches the brand grays. Reproduced here in hex so non-Tailwind targets are not left guessing.",
      "50": { "$value": "#fafaf9" },
      "100": { "$value": "#f5f5f4", "$description": "Subtle fills (ghost-button hover, table header band)." },
      "200": { "$value": "#e7e5e4", "$description": "Default border / hairline." },
      "300": { "$value": "#d6d3d1", "$description": "Input border." },
      "400": { "$value": "#a8a29e", "$description": "Muted text, icons, placeholders." },
      "500": { "$value": "#78716c", "$description": "Secondary text." },
      "600": { "$value": "#57534e", "$description": "Body text on light surfaces (ghost button label)." },
      "700": { "$value": "#44403c" },
      "800": { "$value": "#292524" },
      "900": { "$value": "#1c1917" }
    },

    "status": {
      "$description": "Status colors use Tailwind default scales. Semantic mapping: success=moss, error=red, warning=amber, running/primary=clay, neutral=stone.",
      "red-50": { "$value": "#fef2f2" },
      "red-200": { "$value": "#fecaca" },
      "red-300": { "$value": "#fca5a5" },
      "red-500": { "$value": "#ef4444" },
      "red-600": { "$value": "#dc2626" },
      "red-700": { "$value": "#b91c1c" },
      "amber-50": { "$value": "#fffbeb" },
      "amber-200": { "$value": "#fde68a" },
      "amber-500": { "$value": "#f59e0b" },
      "amber-600": { "$value": "#d97706" },
      "amber-700": { "$value": "#b45309" },
      "amber-800": { "$value": "#92400e" }
    },

    "semantic": {
      "$description": "Aliases that name intent rather than hue. Prefer these in product code.",
      "canvas": { "$value": "{color.brand.cream}" },
      "surface": { "$value": "#ffffff", "$description": "Card / field / raised surface — pure white on the cream canvas." },
      "text": { "$value": "{color.brand.ink}" },
      "text-muted": { "$value": "{color.neutral.400}" },
      "text-secondary": { "$value": "{color.neutral.500}" },
      "border": { "$value": "{color.neutral.200}" },
      "border-strong": { "$value": "{color.neutral.300}" },
      "primary": { "$value": "{color.brand.clay.500}" },
      "primary-strong": { "$value": "{color.brand.clay.600}" },
      "action": { "$value": "{color.brand.ink}", "$description": "Primary button fill — solid ink, not clay." },
      "success": { "$value": "{color.brand.moss}" },
      "error": { "$value": "{color.status.red-600}" },
      "warning": { "$value": "{color.status.amber-600}" },
      "focus-ring": { "$value": "rgba(217, 119, 87, 0.3)", "$description": "clay-500 at 30% — focus:ring-clay-500/30." }
    }
  },

  "fontFamily": {
    "$type": "fontFamily",
    "display": { "$value": ["Bricolage Grotesque", "Hanken Grotesk", "ui-sans-serif", "system-ui", "Arial", "sans-serif"], "$description": "Headings, titles, button labels." },
    "sans": { "$value": ["Hanken Grotesk", "ui-sans-serif", "system-ui", "-apple-system", "Segoe UI", "Roboto", "Arial", "sans-serif"], "$description": "Body and UI text." },
    "mono": { "$value": ["JetBrains Mono", "ui-monospace", "SFMono-Regular", "Menlo", "Consolas", "monospace"], "$description": "Code, prompts, outputs, numeric/technical labels, eyebrows." }
  },

  "fontWeight": {
    "$type": "fontWeight",
    "regular": { "$value": 400 },
    "medium": { "$value": 500 },
    "semibold": { "$value": 600 },
    "bold": { "$value": 700, "$description": "Deployed for display/sans only; mono ships 400/500/600." }
  },

  "fontSize": {
    "$type": "dimension",
    "$description": "The system uses a small set of named roles rather than a deep ladder. These are the sizes actually deployed.",
    "2xs": { "$value": "10px", "$description": "Smallest micro-label (text-[10px])." },
    "eyebrow": { "$value": "11px", "$description": "Mono eyebrow/kicker labels." },
    "xs": { "$value": "12px" },
    "mono-block": { "$value": "13px", "$description": "Prompt/output monospace blocks." },
    "sm": { "$value": "14px", "$description": "Default UI / body size." },
    "base": { "$value": "16px", "$description": "Panel titles." },
    "xl": { "$value": "20px", "$description": "App title (Lab wordmark)." }
  },

  "lineHeight": {
    "$type": "number",
    "none": { "$value": 1 },
    "tight": { "$value": 1.1 },
    "normal": { "$value": 1.5 },
    "relaxed": { "$value": 1.625, "$description": "Used by .mono-block." }
  },

  "letterSpacing": {
    "$type": "dimension",
    "tight": { "$value": "-0.025em", "$description": "Display titles (tracking-tight)." },
    "normal": { "$value": "0em" },
    "wide": { "$value": "0.025em", "$description": "uppercase section labels (tracking-wide)." },
    "eyebrow": { "$value": "0.18em", "$description": "uppercase mono eyebrows (tracking-[0.18em])." }
  },

  "space": {
    "$type": "dimension",
    "$description": "4px base scale (Tailwind). Steps actually used across the app.",
    "0": { "$value": "0px" },
    "0.5": { "$value": "2px" },
    "1": { "$value": "4px" },
    "1.5": { "$value": "6px" },
    "2": { "$value": "8px" },
    "2.5": { "$value": "10px" },
    "3": { "$value": "12px" },
    "3.5": { "$value": "14px" },
    "4": { "$value": "16px" },
    "5": { "$value": "20px" },
    "6": { "$value": "24px" },
    "8": { "$value": "32px" }
  },

  "radius": {
    "$type": "dimension",
    "sm": { "$value": "4px", "$description": "rounded — small chips/indicators." },
    "md": { "$value": "6px", "$description": "rounded-md — icon buttons, inline code." },
    "lg": { "$value": "8px", "$description": "rounded-lg — buttons, fields, output blocks." },
    "xl": { "$value": "12px", "$description": "rounded-xl — cards." },
    "full": { "$value": "9999px", "$description": "rounded-full — badges, pills, dots, sliders." }
  },

  "shadow": {
    "$type": "shadow",
    "sm": {
      "$value": [
        { "color": "rgba(0, 0, 0, 0.05)", "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px" }
      ],
      "$description": "Tailwind default shadow-sm — 1px lift on inputs, pills, stat chips."
    },
    "card": {
      "$value": [
        { "color": "rgba(20, 20, 19, 0.04)", "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px" },
        { "color": "rgba(20, 20, 19, 0.06)", "offsetX": "0px", "offsetY": "4px", "blur": "12px", "spread": "-2px" }
      ],
      "$description": "Resting card elevation."
    },
    "card-hover": {
      "$value": [
        { "color": "rgba(20, 20, 19, 0.05)", "offsetX": "0px", "offsetY": "2px", "blur": "4px", "spread": "0px" },
        { "color": "rgba(20, 20, 19, 0.12)", "offsetX": "0px", "offsetY": "12px", "blur": "28px", "spread": "-6px" }
      ],
      "$description": "Interactive card on hover (paired with -1px translate)."
    },
    "pop": {
      "$value": [
        { "color": "rgba(20, 20, 19, 0.18)", "offsetX": "0px", "offsetY": "8px", "blur": "24px", "spread": "-6px" }
      ],
      "$description": "Popovers / floating surfaces."
    },
    "glow": {
      "$value": [
        { "color": "rgba(217, 119, 87, 0.45)", "offsetX": "0px", "offsetY": "6px", "blur": "20px", "spread": "-4px" }
      ],
      "$description": "Clay glow on primary button hover."
    }
  },

  "duration": {
    "$type": "duration",
    "fast": { "$value": "200ms", "$description": "Default transition (buttons, cards)." },
    "reveal": { "$value": "500ms", "$description": "fade-up entrance." },
    "tab": { "$value": "300ms", "$description": "Tab underline." },
    "shimmer": { "$value": "1600ms", "$description": "Eval progress shimmer (loops)." },
    "pulse": { "$value": "1400ms", "$description": "pulse-soft (loops)." }
  },

  "easing": {
    "$type": "cubicBezier",
    "reveal": { "$value": [0.22, 1, 0.36, 1], "$description": "fade-up easing — soft, decelerating." },
    "linear": { "$value": [0, 0, 1, 1], "$description": "shimmer." }
  },

  "breakpoint": {
    "$type": "dimension",
    "$description": "Tailwind defaults. The app uses sm/md/lg only.",
    "sm": { "$value": "640px" },
    "md": { "$value": "768px" },
    "lg": { "$value": "1024px" }
  },

  "size": {
    "$type": "dimension",
    "container": { "$value": "1280px", "$description": "max-w-7xl — header, tabs, main, footer share this width." }
  },

  "zIndex": {
    "$type": "number",
    "$description": "No formal scale exists in the source — only these two values are used. See foundations.md (gap).",
    "backdrop": { "$value": -10, "$description": "Fixed atmosphere layer (body::before)." },
    "header": { "$value": 20, "$description": "Sticky header." }
  }
}
